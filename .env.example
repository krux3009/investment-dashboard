# Copy to .env and fill in. .env is gitignored.

# Dash dev server
DASH_PORT=8050
DASH_HOST=127.0.0.1
DASH_DEBUG=true

# moomoo OpenD gateway (defaults match a local OpenD GUI on this machine)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# Optional: trading password for trade-side calls (leave blank for quote-only / SIMULATE).
# Trade unlock must still happen in the OpenD GUI manually — deliberate human-in-the-loop.
MOOMOO_TRADE_PWD=
MOOMOO_SECURITY_FIRM=FUTUSG
MOOMOO_TRD_ENV=SIMULATE
# Comma-separated list. Add HK if you hold HK positions.
MOOMOO_MARKETS=US,HK

# Benchmarks rendered on the /portfolio page's "Portfolio vs ___" chart.
# Comma-separated yfinance symbols; the chart and the [learn more]
# advisor commentary scale to however many you set. Defaults to SPY
# alone if unset. Useful additions: SMH (semiconductor / AI-chip
# industry), QQQ (NASDAQ-100 / US tech), STI (Singapore market),
# HSI (Hong Kong market). Pick benchmarks that overlap your book so
# the comparison is meaningful.
MOOMOO_BENCHMARKS=SPY,SMH

# First-run convenience: set to true to render canned PLTR/ANET/VRT demo data
# without depending on real OpenD positions. Flip to false once your account
# is unlocked and SIMULATE/REAL has positions to show.
MOOMOO_USE_DEMO=true

# Demo scenario, used only when MOOMOO_USE_DEMO=true:
#   default  -> +7% portfolio, plausible up day (the seed dataset)
#   bad_day  -> ~-12% across the book, stress-tests the calm-under-volatility design
#   empty    -> no positions, renders the empty state for visual review
MOOMOO_DEMO_SCENARIO=default

# Anthropic API key — powers /api/digest (AI daily digest). Get one at
# https://console.anthropic.com/. Without it, /api/digest returns 503 with
# a hint so the rest of the dashboard keeps working.
ANTHROPIC_API_KEY=
# Override the digest model. Defaults to Sonnet 4.6.
ANTHROPIC_DIGEST_MODEL=claude-sonnet-4-6

# Reddit User-Agent — powers /api/reddit/{code} (per-stock retail
# discussion snapshot in the drill-in). The dashboard hits Reddit's
# public JSON endpoints (no auth, no API key — Reddit's Nov-2025
# Responsible Builder Policy gates new OAuth keys behind a manual
# review queue, but the public read-only JSON endpoints stay open).
# Optional: override the default UA. Reddit asks UAs identify the
# app + operator, but any descriptive UA works for unauth read-only
# access. See reddit-setup.md.
# REDDIT_USER_AGENT=investment-dashboard/0.1 by /u/<your_reddit_username>
