# Copy to .env and fill in. .env is gitignored.

# Dash dev server
DASH_PORT=8050
DASH_HOST=127.0.0.1
DASH_DEBUG=true

# moomoo OpenD gateway (defaults match a local OpenD GUI on this machine)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# Optional: trading password for trade-side calls (leave blank for quote-only / SIMULATE).
# Trade unlock must still happen in the OpenD GUI manually — deliberate human-in-the-loop.
MOOMOO_TRADE_PWD=
MOOMOO_SECURITY_FIRM=FUTUSG
