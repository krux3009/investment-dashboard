# Copy to .env and fill in. .env is gitignored.

# Dash dev server
DASH_PORT=8050
DASH_HOST=127.0.0.1
DASH_DEBUG=true

# moomoo OpenD gateway (defaults match a local OpenD GUI on this machine)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111

# Optional: trading password for trade-side calls (leave blank for quote-only / SIMULATE).
# Trade unlock must still happen in the OpenD GUI manually — deliberate human-in-the-loop.
MOOMOO_TRADE_PWD=
MOOMOO_SECURITY_FIRM=FUTUSG
MOOMOO_TRD_ENV=SIMULATE
# Comma-separated list. Add HK if you hold HK positions.
MOOMOO_MARKETS=US,HK

# First-run convenience: set to true to render canned PLTR/ANET/VRT demo data
# without depending on real OpenD positions. Flip to false once your account
# is unlocked and SIMULATE/REAL has positions to show.
MOOMOO_USE_DEMO=true
